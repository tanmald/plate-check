# Supabase Edge Functions Environment Variables
# Copy this file to .env and fill in your actual values.
# In production, set these with `supabase secrets set NAME=value` instead —
# Supabase Edge Functions don't read a committed .env file.

# Used by analyze-meal, parse-nutrition-plan, and extract-ingredients
# (GPT-4o handles both vision and text/OCR — no separate vision/OCR provider needed)
OPENAI_API_KEY=your_openai_api_key_here

# Auto-injected by Supabase at runtime — no need to set these yourself:
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
